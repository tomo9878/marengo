{
  "name": "triomphe-a-marengo",
  "version": "0.1.0",
  "description": "Triomphe à Marengo - online wargame",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "build-map": "node scripts/build-map.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "projects": [
      {
        "displayName": "server",
        "testEnvironment": "node",
        "testMatch": ["**/tests/engine/**/*.test.js", "**/tests/server/**/*.test.js"]
      },
      {
        "displayName": "client",
        "testEnvironment": "node",
        "testMatch": ["**/tests/client/**/*.test.js"]
      }
    ]
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
